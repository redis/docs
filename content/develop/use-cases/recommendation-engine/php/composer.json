{
    "name": "redis/recommendation-engine-php-demo",
    "description": "Redis recommendation-engine demo using Predis and TransformersPHP.",
    "require": {
        "php": ">=8.1",
        "ext-ffi": "*",
        "predis/predis": "^3.0",
        "codewithkyrian/transformers": "^0.5",
        "rindow/rindow-matlib-ffi": "1.0.*"
    },
    "autoload": {
        "psr-4": {
            "Redis\\RecommendationEngine\\": ""
        },
        "classmap": [
            "Embedder.php",
            "Recommender.php"
        ]
    },
    "config": {
        "allow-plugins": {
            "codewithkyrian/transformers-libsloader": true
        }
    }
}
